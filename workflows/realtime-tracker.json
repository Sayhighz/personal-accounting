    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json.output?.trim() || '{}';\nconst parsed = $('Route Intent').first().json;\n\nlet type = 'รายจ่าย';\nlet category = 'อื่น ๆ';\n\ntry {\n  const jsonMatch = agentOutput.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    const result = JSON.parse(jsonMatch[0]);\n    type = result.type || type;\n    category = result.category || category;\n  }\n} catch (e) {}\n\nreturn [{\n  json: {\n    ...parsed,\n    type,\n    category,\n    replyMessage: `บันทึก${type} ${Number(parsed.amount).toLocaleString()} บาท\\nรายการ: ${parsed.description}\\nหมวดหมู่: ${category} ✅`\n  }\n}];"
      },
