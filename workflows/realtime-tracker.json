    {
      "parameters": {
        "jsCode": "const { text, replyToken } = $input.first().json;\nconst replyMessage = `ไม่เข้าใจคำสั่ง \"${text}\"\\n\\n📝 วิธีใช้งาน:\\n• บันทึกรายการ → พิมพ์รายการพร้อมจำนวนเงิน\\n  เช่น: ข้าวมันไก่ 45, ค่าไฟ 800, รับเงินเดือน 15000\\n• ดูสรุป → พิมพ์ว่า สรุป`;\nreturn [{ json: { replyToken, replyMessage } }];"
      },
      "id": "d6d8a492-43a9-4b42-b6ad-6a178b5bf6cc",
      "name": "Help Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3674,
        3626
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=รายการ: {{ $json.description }}\nจำนวน: {{ $json.amount }} บาท\n\nวิเคราะห์รายการนี้และตอบในรูปแบบ JSON เท่านั้น ห้ามมีข้อความอื่น:\n{\"type\": \"รายรับ หรือ รายจ่าย\", \"category\": \"ชื่อหมวดหมู่\"}",
        "options": {
          "systemMessage": "คุณเป็นผู้ช่วยจัดประเภทและหมวดหมู่รายการทางการเงิน\n\nหน้าที่:\n1. วิเคราะห์ว่ารายการนี้คือ \"รายรับ\" หรือ \"รายจ่าย\"\n2. จัดหมวดหมู่ที่เหมาะสม\n\nหมวดหมู่รายรับ: เงินเดือน, ขายสินค้า, ค่าจ้าง, โบนัส, ดอกเบี้ย, ลงทุน, อื่น ๆ\nหมวดหมู่รายจ่าย: อาหาร, เดินทาง, ที่พัก, สุขภาพ, บันเทิง, ช้อปปิ้ง, ค่าน้ำค่าไฟ, การศึกษา, อื่น ๆ\n\nตอบในรูปแบบ JSON เท่านั้น ห้ามมีข้อความอื่นนอก JSON\nตัวอย่าง: {\"type\": \"รายจ่าย\", \"category\": \"อาหาร\"}"
        }
      },
