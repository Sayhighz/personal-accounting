    {
      "parameters": {
        "jsCode": "const event = $input.first().json;\nconst text = event.message?.text?.trim();\nconst replyToken = event.replyToken;\nconst userId = event.source?.userId;\n\nif (!text) return [];\n\nreturn [{ json: { text, replyToken, userId } }];"
      },
      "id": "0db3a876-fea9-4a23-a8ec-9c5847c28dad",
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3002,
        3194
      ]
    },
    {
      "parameters": {
        "jsCode": "const { text, replyToken, userId } = $input.first().json;\n\n// ตรวจ pattern 1: คำว่า \"สรุป\" (regex)\nif (/^สรุป$/i.test(text)) {\n  return [{ json: { text, replyToken, userId, intent: 'summary' } }];\n}\n\n// ตรวจ pattern 2: มีตัวเลข → บันทึกรายการ\nconst amountMatch = text.match(/(\\d+(?:\\.\\d+)?)/)\nif (amountMatch) {\n  const amount = parseFloat(amountMatch[1]);\n  const description = text.replace(amountMatch[0], '').replace(/บาท/g, '').trim();\n  const now = new Date();\n  const dateStr = now.toLocaleDateString('th-TH', { year: 'numeric', month: '2-digit', day: '2-digit' });\n  const timeStr = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });\n  return [{ json: { text, replyToken, userId, intent: 'record', amount, description, date: dateStr, time: timeStr } }];\n}\n\n// ไม่ตรง pattern ใด → unknown\nreturn [{ json: { text, replyToken, userId, intent: 'unknown' } }];"
      },
