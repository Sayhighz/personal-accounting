    {
      "parameters": {
        "jsCode": "const userId = $('Route Intent').first().json.userId;\nconst replyToken = $('Route Intent').first().json.replyToken;\nconst rows = $input.all().map(i => i.json);\n\n// filter เฉพาะ user คนนี้\nconst userRows = rows.filter(r => r.UserID === userId);\n\nif (userRows.length === 0) {\n  return [{ json: { replyToken, replyMessage: 'ยังไม่มีรายการของคุณในระบบ\\nลองบันทึกรายการก่อนเลย เช่น: ข้าวมันไก่ 45' } }];\n}\n\nlet totalIncome = 0;\nlet totalExpense = 0;\nconst categoryExpense = {};\nconst categoryIncome = {};\n\nfor (const row of userRows) {\n  const amount = parseFloat(row.Amount) || 0;\n  const category = row.Category || 'อื่น ๆ';\n  if (row.Type === 'รายรับ') {\n    totalIncome += amount;\n    categoryIncome[category] = (categoryIncome[category] || 0) + amount;\n  } else {\n    totalExpense += amount;\n    categoryExpense[category] = (categoryExpense[category] || 0) + amount;\n  }\n}\n\nconst balance = totalIncome - totalExpense;\n\nlet expenseLines = Object.entries(categoryExpense)\n  .sort((a, b) => b[1] - a[1])\n  .map(([cat, amt]) => `  • ${cat}: ${amt.toLocaleString()} บาท`)\n  .join('\\n');\n\nlet incomeLines = Object.entries(categoryIncome)\n  .sort((a, b) => b[1] - a[1])\n  .map(([cat, amt]) => `  • ${cat}: ${amt.toLocaleString()} บาท`)\n  .join('\\n');\n\nlet replyMessage = `📊 สรุปรายการทั้งหมดของคุณ\\n`;\nreplyMessage += `(${userRows.length} รายการ)\\n\\n`;\n\nif (incomeLines) {\n  replyMessage += `💰 รายรับ: ${totalIncome.toLocaleString()} บาท\\n${incomeLines}\\n\\n`;\n}\nif (expenseLines) {\n  replyMessage += `💸 รายจ่าย: ${totalExpense.toLocaleString()} บาท\\n${expenseLines}\\n\\n`;\n}\n\nreplyMessage += `${balance >= 0 ? '✅' : '⚠️'} ยอดคงเหลือ: ${balance.toLocaleString()} บาท`;\n\nreturn [{ json: { replyToken, replyMessage } }];"
      },
